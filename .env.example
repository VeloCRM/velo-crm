# Velo CRM — Environment Configuration
# Copy this file to .env and fill in real values.
# Get Supabase keys from: https://supabase.com/dashboard → Project Settings → API


# ── Client (Vite) ─────────────────────────────────────────────────────────
# Anything prefixed VITE_ is exposed to the browser bundle.

# Supabase project (REQUIRED — production builds throw without these)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Operator contact target — surfaced in Auth.jsx and TestAccountBanner.
# Use a wa.me link, mailto:, or tel: URL. Do NOT hardcode phone numbers
# anywhere in source.
#   Examples:  https://wa.me/9647XXXXXXXXX
#              mailto:hello@your-agency.example
#              tel:+9647XXXXXXXXX
VITE_OPERATOR_CONTACT=


# ── Server (Vercel functions) ─────────────────────────────────────────────
# Never prefix these with VITE_ — they must NOT reach the browser.

# Supabase service-role key. Used by /api/auth/create-test-account,
# /api/cron/cleanup-test-accounts, and other server-side bypass paths.
VITE_SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Cron auth — required by /api/cron/cleanup-test-accounts. Vercel injects
# `Authorization: Bearer ${CRON_SECRET}` on cron-triggered calls. Generate
# with: openssl rand -hex 32
CRON_SECRET=

# Anthropic API key — used Phase 4 by the server-side Claude proxy that
# replaces the current client-side key exposure.
ANTHROPIC_API_KEY=
