# Velo CRM — Environment Configuration
# Copy this file to .env and fill in real values.
# Get Supabase keys from: https://supabase.com/dashboard → Project Settings → API


# ── Required for client (browser-exposed) ───────────────────────────────────
# Anything prefixed VITE_ is bundled into the production JS and reaches the
# browser. Never put a secret here.

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Public URL of the deployed app — used in invitation links, etc.
VITE_APP_URL=http://localhost:5173

# Operator contact target — surfaced in Auth.jsx and TestAccountBanner.
# Use a wa.me link, mailto:, or tel: URL.
#   Examples:  https://wa.me/9647XXXXXXXXX
#              mailto:hello@your-agency.example
#              tel:+9647XXXXXXXXX
VITE_OPERATOR_CONTACT=+9647721222172


# ── Required for server (Vercel functions ONLY — never expose to client) ────
# These names must NOT carry the VITE_ prefix or they would be bundled into
# the browser JS, leaking the secret.

# Supabase service-role key. Used by every api/* function that needs to
# bypass RLS (auth provisioning, cron cleanup, server-side webhooks, etc.).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic API key — used by api/ai/chat.js (the server-side Claude proxy).
# The client never sees this.
ANTHROPIC_API_KEY=sk-ant-...

# WhatsApp Business Cloud API credentials — used by api/whatsapp/* and the
# inbound webhook at api/webhooks/whatsapp.js.
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_BUSINESS_PHONE_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Cron auth — required by api/cron/cleanup-test-accounts. Vercel injects
# `Authorization: Bearer ${CRON_SECRET}` on cron-triggered calls. Generate
# with: openssl rand -hex 32
CRON_SECRET=long-random-string


# ── Optional ────────────────────────────────────────────────────────────────
NODE_ENV=development
