# ─────────────────────────────────────────────────────────────────────────────
# GHL (GoHighLevel) migration credentials
# Copy this file to `.env.local` (gitignored) and fill in the values.
# NEVER commit real credentials. If a token was ever committed, ROTATE it in
# GHL first — the value in git history stays readable forever.
# ─────────────────────────────────────────────────────────────────────────────

# v2 Private Integration Token (PIT) — used as the Bearer credential by the
# export runner (scripts/run-export.mjs). Generate in GHL: Settings → Private
# Integrations. Required by run-export.mjs.
GHL_API_TOKEN=

# GHL location (sub-account) id to export from. Differs per clinic and for
# staging. Required by download-ghl-docs.mjs and the exploration script.
# Find it in the GHL app URL: app.gohighlevel.com/v2/location/<ID>/...
GHL_LOCATION_ID=

# Older v1 location API key, IF you use one that differs from the PIT above.
# Most direct-run scripts (ghl-export.mjs, ghl-fetch-notes.mjs, fetch-documents.mjs,
# ghl-api-exploration.mjs) accept the Bearer credential as GHL_API_KEY
# (or via --api-key=). You can set this to the same value as GHL_API_TOKEN.
GHL_API_KEY=
